# Social Slash - Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# LATE API (Required)
# =============================================================================
# Get your API key at: https://getlate.dev
LATE_API_KEY=your_late_api_key_here

# =============================================================================
# AI ENHANCEMENT (Optional)
# =============================================================================
# These are optional. If not set, AI enhancement will be disabled.

# Google Gemini API (default AI provider)
# Get at: https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API (alternative AI provider)
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit this file with real values to version control
# 2. The .gitignore file excludes .env and .env.local
# 3. For production, set environment variables in your hosting platform
