# Social Slash - Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# LATE API (Required)
# =============================================================================
# Get your API key at: https://getlate.dev
LATE_API_KEY=your_late_api_key_here

# =============================================================================
# AI ENHANCEMENT (Optional)
# =============================================================================
# These are optional. If not set, AI enhancement will be disabled.

# Google Gemini API (default AI provider)
# Get at: https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API (alternative AI provider)
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# MCP SERVER (Railway deployment)
# =============================================================================
# Bearer token protecting /mcp endpoint
MCP_AUTH_TOKEN=your_mcp_auth_token_here

# OAuth 2.0 credentials for Claude.ai custom connector
OAUTH_CLIENT_ID=your_oauth_client_id_here
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here

# =============================================================================
# SLASHERBOT — Daily Automated Posting (Optional)
# =============================================================================

# Google Chat SLASHERBOT space webhook
# Space: https://chat.google.com/u/0/app/management/AAQAlyk161I
GCHAT_WEBHOOK_SOCIAL_SLASH=https://chat.googleapis.com/v1/spaces/AAQAlyk161I/messages?key=...&token=...

# HMAC secret for approval button URL security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APPROVAL_TOKEN_SECRET=generate-a-random-32-char-secret-here

# Set true on Railway to activate the daily scheduler
SCHEDULER_ENABLED=false

# Timezone for scheduled jobs (default: America/New_York)
SCHEDULER_TIMEZONE=America/New_York

# Override the base URL used in approval card buttons (auto-detected on Railway)
# APPROVAL_BASE_URL=https://web-production-c9cb9.up.railway.app

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit this file with real values to version control
# 2. The .gitignore file excludes .env and .env.local
# 3. For production, set environment variables in your hosting platform
